{
  "name": "kolscan-scraper",
  "version": "1.0.0",
  "type": "module",
  "description": "Scrape all KOL wallet data from kolscan.io leaderboard + GMGN smart money",
  "main": "scrape.js",
  "scripts": {
    "scrape": "node scrape.js",
    "scrape:axiom": "node scrape-axiom.js",
    "scrape:x": "node scrape-x-profiles.js",
    "scrape:x-tracker": "node scrape-gmgn-x-tracker.js",
    "scrape:gmgn": "node scrape-gmgn-ranks.js",
    "scrape:monad": "node scrape-gmgn-monad.js",
    "scrape:polymarket": "node scrape-polymarket.js",
    "monitor:rewards": "node monitor-gmgn-rewards.js",
    "monitor:rewards-login": "node monitor-gmgn-rewards.js --login",
    "monitor:rewards-poll": "node monitor-gmgn-rewards.js --poll 300",
    "setup": "npm install && npx playwright install chromium && sudo npx playwright install-deps chromium",
    "api": "bun api/index.ts",
    "mcp": "bun mcp/index.ts",
    "dev": "cd site && npm run dev",
    "build": "cd site && npm run build",
    "fetch": "bun fetchers/index.ts",
    "fetch:free": "bun fetchers/index.ts --free-only",
    "fetch:list": "bun fetchers/index.ts --list",
    "fetch:solana": "bun fetchers/index.ts --only dexscreener,geckoterminal,gmgn,kolscan,solana-ecosystem,helius,birdeye,solscan",
    "fetch:evm": "bun fetchers/index.ts --only etherscan,blockscout,moralis,alchemy,covalent,debank,zerion,chainbase",
    "fetch:analytics": "bun fetchers/index.ts --only dune,flipside,bitquery,thegraph",
    "fetch:market": "bun fetchers/index.ts --only dexscreener,geckoterminal,coingecko,solana-ecosystem"
  },
  "keywords": [
    "kolscan",
    "gmgn",
    "solana",
    "bsc",
    "kol",
    "scraper",
    "leaderboard",
    "crypto",
    "smart-money",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "lightweight-charts": "^5.1.0",
    "playwright": "^1.50.0",
    "xactions": "^3.0.44"
  }
}

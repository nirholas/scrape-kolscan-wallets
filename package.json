{
  "name": "kolscan-scraper",
  "version": "1.0.0",
  "type": "module",
  "description": "Scrape all KOL wallet data from kolscan.io leaderboard + GMGN smart money",
  "main": "scrape.js",
  "scripts": {
    "scrape": "node scrape.js",
    "scrape:axiom": "node scrape-axiom.js",
    "scrape:x": "node scrape-x-profiles.js",
    "scrape:x-tracker": "node scrape-gmgn-x-tracker.js",
    "setup": "npm install && npx playwright install chromium && sudo npx playwright install-deps chromium",
    "api": "bun api/index.ts",
    "mcp": "bun mcp/index.ts",
    "dev": "cd site && npm run dev",
    "build": "cd site && npm run build"
  },
  "keywords": [
    "kolscan",
    "gmgn",
    "solana",
    "bsc",
    "kol",
    "scraper",
    "leaderboard",
    "crypto",
    "smart-money",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.50.0",
    "xactions": "^3.1.0"
  }
}
